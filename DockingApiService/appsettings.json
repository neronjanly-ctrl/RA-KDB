{
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    }
  },
  "Urls": "http://localhost:5070",
  "Antiforgery": {
    "Cookie": "MZ-CSRF",
    "FormFieldName": "MZ-CSRF"
  },
  "CookieConsent": {
    "CookieName": "MZ-GDPR"
  },
  "AllowedHosts": "*",
  "Manifest": {
    "AppName": "Docking & Prediction Service"
  },
  "OpenApi": {
    "RouteTemplate": "/{documentName}/openapi.json",
    "Endpoints": [
      {
        "DocumentName": "v1",
        "Title": "Docking & Prediction Service",
        "Description": "This is a set of APIs that serves the core functionalities for the CCGS & NIDA CDAR centers' docking and prediction websites including the <a href=\"{0}\" target=\"_blank\">Generic Computation Platform</a>."
      }
    ]
  },
  "ClientUrl": "https://www.cbligand.org/g/",
  "ServiceUrls": {
    "ProxyPathBase": "/dockapi",
    "JobHub": "/jobhub",
    "Hangfire": "/hangfire",
    "SwaggerUi": "/swagger",
    "RedocUi": "/redoc"
  },
  "OpenBabel": {
    "SvgBackColor": "none",
    "SvgBlackAndWhite": false,
    "SvgShowAtomIndex": false,
    "SvgDrawAllCarbons": false,
    "SvgUseThickerLines": false,
    "SvgOmitXmlDeclaration": true,
    "SvgUseRealResolution": true,
    "MaxRunTime": 60000
  },
  "ConnectionStrings": {
    "Computation": "Data Source=Workspace/Computation.db;",
    "Hangfire": "Data Source=Workspace/Hangfire.db;"
  },
  "ExternalPrograms": {
    "Python": "python3",
    "Predictor": "Prediction.py",
    "Docker": "jdock",
    "UseVegaForPdbqt": false,
    "BBBUrl": "https://www.cbligand.org/BBB/predictor.php?smiles={0}&algorithm={1}&FingerPrint={2}",
    "BBBTimeout": 300000
  },
  "JobMonitoring": {
    "StaleProgressTimeoutMinutes": 40,
    "CheckCron": "*/10 * * * *"
  },
  "AllowedOrigins": [
    "https://www.cbligand.org"
  ]
}
