{
  "Logging": {
    "LogLevel": {
      "Default": "Error"
    }
  },
  "Urls": "http://localhost:5020",
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "common",
    "ClientId": "916dc631-9b2a-46ab-8f15-66637c671cc0",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc"
  },
  "Antiforgery": {
    "Cookie": "MZ-CSRF",
    "FormFieldName": "MZ-CSRF"
  },
  "CookieConsent": {
    "CookieName": "MZ-RA-KDB"
  },
  "AllowedHosts": "*",
  "Manifest": {
    "AppName": "RA-KDB: Rheumatoid Arthritis Knowledgebase",
    "Keywords": "RA-KDB and Molecular Docking",
    "Description": "RA-KDB is a rheumatoid arthritis molecular docking and network visualization platform for target-ligand computational research.",
    "CopyrightLine": "University of Pittsburgh & Shenzhen University of Advanced Technology",
    "Address": "No. 1 Gongchang Road, Xinhu Sub-district, Guangming District, Shenzhen, Guangdong Province, Shenzhen University of Advanced Technology, P.R. China, 518107"
  },
  "ServiceUrls": {
    "ProxyPathBase": "/g"
  },
  "ExternalUrls": {
    "Hosting": "https://www.cbligand.org/g/",
    "DockingApiDoc": "https://www.cbligand.org/dockapi/swagger",
    "DockingApi": "http://localhost:5070/",
    "JobHub": "//www.cbligand.org/dockapi/jobhub"
  },
  "TargetList": {
    "PropFields": [ "UniProt", "ChEMBL" ]
  },
  "PageSize": {
    "JobOutput": 20,
    "JobList": 16,
    "Guestbook": 20
  },
  "Plotting": {
    "DockingThresholdInteraction": -8.5, //分子对接分数阈值，低于此值表示配体与蛋白质有较强的结合亲和力，
    //csv 文件中保存的数据DockingScore Model 
    "ThresholdForInteraction": 0.9, //配体与ChEMBL已知活性化合物的结构相似度阈值（Tanimoto系数），
    //csv 文件中保存的数据是Similarity Score
    "ThresholdForKnown": 0.95 //判定为'已知配体'（Known Ligand）的严格相似度阈值
  },
  "Formatting": {
    "FingerprintBlockBytes": 4,
    "FingerprintRowBlocks": 6
  },
  "Display": {
    "PreviewLigandModels": false,
    "PreviewLigandFingerprints": false
  },
  "Branding": {
    "DefaultLogoId": "logo_test",
    "NavbarBackgroundColor": "#F8F9FA",
    "NavbarBorderColor": "#E3E6EA",
    "PartnerLogos": [
      {
        "Image": "suat_logo.png",
        "Alt": "Shenzhen University of Advanced Technology",
        "Url": "https://suat-sz.edu.cn/"
      },
      {
        "Image": "szu.jpg",
        "Alt": "Shenzhen University",
        "Url": "https://www.szu.edu.cn/"
      },
      {
        "Image": "suat_bme_logo.png",
        "Alt": "SUAT Faculty of Biomedical Engineering",
        "Url": "https://suat-sz.edu.cn/swyxgcxy/"
      },
      {
        "Image": "suat_pharm_logo.png",
        "Alt": "SUAT Faculty of Pharmaceutical Sciences",
        "Url": "https://pharm.suat-sz.edu.cn/"
      }
    ]
  },
  "Options": {
    "MaxInputLigands": 5,
    "JobFailureThreshold": 0.7
  },
  "Test": {
    "UseMockDataForPlotting": false,
    "PlottingMockDataSize": 30
  },
  "ContactEmails": [
    "yuanone011@gmail.com"
  ]
}
