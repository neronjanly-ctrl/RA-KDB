@model GuestBookModel
@{
    ViewData["Title"] = "GuestBook";
    string domainId = ViewContext.RouteData.Values["domainId"].ToString();
}

<h2>GuestBook</h2>

@*<a class="btn btn-warning" asp-controller="Home" asp-action="NewPost" asp-route-domainId="@domainId" data-toggle="modal" data-target="#newPost">New Post</a>*@

@Html.DisplayFor(o => o.Posts)

<!-- New Post Dialog -->
<div class="modal fade" id="newPost" tabindex="-1" role="dialog" aria-labelledby="postSubject" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="postSubject">New Post</h5>
                <div class="text-nowrap col-auto">
                    <a class="close ml-2" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </a>
                    <a href="" target="_blank" class="close maximizeBtn">
                        <span aria-hidden="true"><i class="fa fa-window-maximize"></i></span>
                    </a>
                </div>
            </div>
            <div class="modal-body">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Pagination -->
<nav aria-label="job list pagination">
    <ul class="pagination justify-content-end">
        @if (Model.PageNum >= 0)
        {
            <li class="page-item@(Model.PageNum > 1 ? "" : " disabled")">
                @*<a class="page-link" asp-controller="Home" asp-action="Guestbook" asp-route-domainId="@domainId" asp-route-pageNum="@(Model.PageNum - 1)" aria-label="Previous">
                    <span aria-hidden="true">&laquo;</span>
                    <span class="sr-only">Previous</span>
                </a>*@
            </li>
            for (var i = 1; i <= Model.PageCount; i++)
            {
                if (i == Model.PageNum)
                {
                    @*<li class="page-item active">
                        <a class="page-link" asp-controller="Home" asp-action="Guestbook" asp-route-domainId="@domainId" asp-route-pageNum="@i">@i<span class="sr-only">(current)</span></a>
                    </li>*@
                }
                else
                {
                    <li class="page-item">
                        @*<a class="page-link" asp-controller="Home" asp-action="Guestbook" asp-route-domainId="@domainId" asp-route-pageNum="@i">@i</a>*@
                    </li>
                }
            }
            @*<li class="page-item">
                    <a class="page-link" asp-controller="Home" asp-action="GuestbookAll" asp-route-domainId="@domainId">View All</a>
                </li>*@
            <li class="page-item@(Model.PageNum < Model.PageCount ? "" : " disabled")">
                @*<a class="page-link" asp-controller="Home" asp-action="Guestbook" asp-route-domainId="@domainId" asp-route-pageNum="@(Model.PageNum + 1)" aria-label="Next">
                    <span aria-hidden="true">&raquo;</span>
                    <span class="sr-only">Next</span>
                </a>*@
            </li>
        }
        else
        {
            <li class="page-item">
                @*<a class="page-link" asp-controller="Home" asp-action="Guestbook" asp-route-domainId="@domainId" asp-route-pageNum="1" aria-label="View paged">View Paged</a>*@
            </li>
        }
    </ul>
</nav>

@section Menu {
    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-route-domainId="@domainId">Home</a></li>
    <li class="nav-item"><a class="nav-link" asp-controller="Job" asp-action="List" asp-route-domainId="@domainId">All Jobs</a></li>
    @*<li class="nav-item active"><a class="nav-link" asp-controller="Home" asp-action="Guestbook" asp-route-domainId="@domainId">Guestbook</a></li>*@
}

@section Scripts {
}