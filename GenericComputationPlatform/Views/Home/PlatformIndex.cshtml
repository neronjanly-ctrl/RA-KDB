@model PlatformIndexViewModel
@using System
@using System.Linq

@{
    ViewData["Title"] = "RA-KDB Platform";

    var raDomain = Model.Domains.FirstOrDefault(o =>
        o.IsPublic &&
        string.Equals(o.Id, "RA", StringComparison.OrdinalIgnoreCase));

    var knowledgeEvidence = new[]
    {
        new
        {
            Title = "Disease-oriented target curation",
            Desc = "The database begins from rheumatoid arthritis-relevant targets rather than generic records, so the knowledge layer already reflects disease context, target significance, and research usefulness."
        },
        new
        {
            Title = "Structured interpretation for each record",
            Desc = "Protein entries are organized as readable records with annotations, summaries, and linked biological meaning, making them appropriate for both expert review and downstream computational work."
        },
    };

    var capabilityCards = new[]
    {
        new
        {
            Eyebrow = "Protein records",
            Title = "Interpretable target cards",
            Desc = "Researchers can review structured protein cards that summarize target identity, rheumatoid arthritis relevance, and supporting annotations before moving into docking-related work."
        },
        new
        {
            Eyebrow = "Docking workflows",
            Title = "Computational investigation",
            Desc = "The docking module extends the knowledge layer into practical analysis, allowing users to organize target-ligand work and interpret outputs in the same disease-aware setting."
        }
    };

    var featuredProteins = Model.FeaturedProteins.Take(3).ToList();
    var overviewBanner = Url.Content("~/images/version3/ra_hero1.png");
    var knowledgeBanner = Url.Content("~/images/version3/ra_hero2.png");
    var dockingBanner = Url.Content("~/images/version3/ra_hero3.png");
}

@section Menu {
    <li class="nav-item dropdown ra-section-dropdown nav-item-with-separator">
        <a class="nav-link dropdown-toggle ra-section-dropdown-toggle"
           href="#"
           id="IntroductionMenu"
           role="button"
           data-toggle="dropdown"
           aria-haspopup="true"
           aria-expanded="false">
            <span class="ra-section-dropdown-label">Introduction</span>
        </a>

        <div class="dropdown-menu dropdown-menu-right ra-section-dropdown-menu"
             aria-labelledby="IntroductionMenu">
            <a class="dropdown-item ra-section-dropdown-item" href="#about">Overview</a>
            <a class="dropdown-item ra-section-dropdown-item" href="#knowledge">Knowledge Base</a>
            <a class="dropdown-item ra-section-dropdown-item" href="#capabilities">Docking</a>
        </div>
    </li>

    <li class="nav-item nav-item-with-separator">
        <a class="nav-link" href="@Url.Action("Index", "Home", new { domainId = raDomain?.Id ?? "RA" })">
            Enter RA Workspace
        </a>
    </li>

    <li class="nav-item nav-item-with-separator">
        <a class="nav-link" href="@Url.Action("Help", "Home", new { domainId = raDomain?.Id ?? "RA" })">
            Guideline
        </a>
    </li>
}

@section Styles {
    <link rel="stylesheet" href="~/css/page1.css" asp-append-version="true" />
}

<div class="ra-platform-home">
    <section class="ra-overview ra-module ra-module--dark" id="about">
        <div class="ra-banner">
            <img src="@overviewBanner" alt="Rheumatoid arthritis computational research" />
            <div class="ra-banner-overlay"></div>
            <div class="ra-banner-inner ra-container">
                <div class="ra-kicker">Overview</div>
                <h1 class="ra-hero-title">A research platform for rheumatoid arthritis knowledgebase and docking</h1>
                <p class="ra-hero-desc">
                    RA-KDB brings together curated disease-relevant targets, structured protein records, and docking workflows in one research setting, allowing users to move from target understanding to computational investigation without leaving the same scholarly environment.
                </p>
            </div>
        </div>
    </section>

    <section class="ra-knowledge ra-module ra-module--light" id="knowledge">
        <div class="ra-banner ra-banner--section">
            <img src="@knowledgeBanner" alt="Knowledge base and rheumatoid arthritis context" />
            <div class="ra-banner-overlay ra-banner-overlay--light"></div>
            <div class="ra-banner-inner ra-container ra-banner-inner--compact">
                <div class="ra-kicker">Knowledge Base</div>
                <h2 class="ra-section-title">A disease-oriented knowledge layer designed to support interpretation</h2>
            </div>
        </div>

        <div class="ra-module-body ra-container">
            <div class="ra-editorial-head">
                <p class="ra-section-desc">
                    The knowledge base is the platform's foundation. It explains where the records come from, how they are structured, and why they are suitable for rheumatoid arthritis-oriented interpretation before any docking step begins.
                </p>
            </div>

            <div class="ra-knowledge-grid">
                <div class="ra-evidence-list">
                    @foreach (var item in knowledgeEvidence)
                    {
                        <article class="ra-evidence-item">
                            <h3 class="ra-evidence-title">@item.Title</h3>
                            <p class="ra-body">@item.Desc</p>
                        </article>
                    }
                </div>

            </div>
            <div class="ra-featured-block">
                <div class="ra-featured-head">
                    <div>
                        <div class="ra-side-note-label">Selected records</div>
                        <h3 class="ra-featured-title">Featured protein cards</h3>
                    </div>
                    <p class="ra-featured-desc">
                        A small set of cards is shown below as examples of how the knowledge base surfaces interpretable records for later exploration.
                    </p>
                </div>

                @if (featuredProteins.Count > 0)
                {
                    <div class="ra-view-toggle ra-featured-toggle">
                        <button class="ra-toggle-btn is-active" type="button" data-view="card" data-target="featured">
                            Card view
                        </button>
                        <button class="ra-toggle-btn" type="button" data-view="list" data-target="featured">
                            Compact list
                        </button>
                    </div>

                    <div class="ra-card-view" id="raFeaturedCardView">
                        @foreach (var protein in featuredProteins)
                        {
                            <article class="ra-protein-card">
                                <img class="ra-protein-thumb" src="@protein.ImageUrl" alt="@protein.ProteinName" />

                                <div class="ra-protein-body">
                                    <h3 class="ra-protein-title">
                                        @protein.ProteinName
                                    </h3>

                                    <div class="ra-protein-meta">
                                        <div><strong>Organism:</strong> @protein.Organism</div>                                       
                                        <div><strong>Gene:</strong> @protein.Gene</div>
                                    </div>

                                    <div class="ra-badge-row">
                                        <span class="ra-badge">Knowledge base</span>
                                        <span class="ra-badge">RA-oriented</span> 
                                    </div>

                                    <div class="ra-link-row">
                                        <a class="ra-protein-action"
                                           data-toggle="modal"
                                           data-target="#proteinInfo"
                                           data-pname="@protein.ProteinName"
                                           asp-controller="Protein"
                                           asp-action="Details"
                                           asp-route-domainId="@protein.DomainId"
                                           asp-route-cavityId="@protein.CavityId">
                                            View details
                                        </a>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>

                    <div class="ra-list-view" id="raFeaturedListView" style="display:none;">
                        <div class="ra-table-wrap">
                            <table class="ra-list-table">
                                <thead>
                                    <tr>
                                        <th>Protein</th>
                                        <th>Gene</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var protein in featuredProteins)
                                    {
                                        <tr>
                                            <td>@protein.ProteinName</td>
                                            <td>@protein.Gene</td>
                                            <td>
                                                <a class="ra-protein-action"
                                                   data-toggle="modal"
                                                   data-target="#proteinInfo"
                                                   data-pname="@protein.ProteinName"
                                                   asp-controller="Protein"
                                                   asp-action="Details"
                                                   asp-route-domainId="@protein.DomainId"
                                                   asp-route-cavityId="@protein.CavityId">
                                                    View
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div class="ra-protein-empty">
                        No featured protein cards are available yet. Once sample entries are configured for the RA domain, they will appear here.
                    </div>
                }
            </div>      
        </div>
    </section>

    <section class="ra-capabilities ra-module ra-module--paper" id="capabilities">
        <div class="ra-banner ra-banner--section ra-banner--warm">
            <img src="@dockingBanner" alt="Docking workflow and computational analysis" />
            <div class="ra-banner-overlay ra-banner-overlay--warm"></div>
            <div class="ra-banner-inner ra-container ra-banner-inner--compact">
                <div class="ra-kicker">Docking</div>
                <h2 class="ra-section-title">A computational module that extends knowledge records into practical analysis</h2>
            </div>
        </div>

        <div class="ra-module-body ra-container">
            <div class="ra-cap-layout">
                <div class="ra-cap-copy">
                    <p class="ra-section-desc">
                        The docking module gives the platform operational value. It allows researchers to continue from readable target records into actual computational investigation while preserving the biological and disease-oriented context established by the knowledge base.
                    </p>
                </div>

                <div class="ra-cap-editorial">
                    @foreach (var card in capabilityCards)
                    {
                        <article class="ra-cap-item">
                            <div class="ra-side-note-label">@card.Eyebrow</div>
                            <h3 class="ra-cap-title">@card.Title</h3>
                            <p>@card.Desc</p>
                        </article>
                    }
                </div>
            </div>

            <div class="ra-research-band">
                <div class="ra-side-note-label">Research value</div>
                <p>
                    In this part, docking is designed for caculating the scores for different proteins 
                    with certain drug given by you visitor.
                </p>
            </div>
        </div>
    </section>
</div>

<div class="modal fade" id="proteinInfo" tabindex="-1" role="dialog" aria-labelledby="proteinName" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="proteinName"></h5>
                <div class="text-nowrap col-auto">
                    <a class="close ml-2" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </a>
                    <a href="" target="_blank" class="close maximizeBtn" rel="noopener noreferrer">
                        <span aria-hidden="true"><i class="fa fa-window-maximize"></i></span>
                    </a>
                </div>
            </div>
            <div class="modal-body"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/ngl/ngl.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const toggleButtons = document.querySelectorAll('.ra-featured-toggle .ra-toggle-btn');
            const cardView = document.getElementById('raFeaturedCardView');
            const listView = document.getElementById('raFeaturedListView');

            toggleButtons.forEach(button => {
                button.addEventListener('click', function () {
                    const view = this.dataset.view;

                    toggleButtons.forEach(btn => btn.classList.remove('is-active'));
                    this.classList.add('is-active');

                    if (view === 'card') {
                        cardView.style.display = '';
                        listView.style.display = 'none';
                    } else {
                        cardView.style.display = 'none';
                        listView.style.display = '';
                    }
                });
            });
        });
        (() => {
            if (typeof setupProteinInfoModal === 'function') {
                setupProteinInfoModal();
            }

            const anchorLinks = Array.from(document.querySelectorAll('a[href^="#"]'));
            anchorLinks.forEach((link) => {
                const targetId = link.getAttribute('href');
                if (!targetId || targetId === '#') {
                    return;
                }

                const target = document.querySelector(targetId);
                if (!target) {
                    return;
                }

                link.addEventListener('click', (event) => {
                    event.preventDefault();
                    const nav = document.querySelector('.site-navbar');
                    const navHeight = nav ? nav.getBoundingClientRect().height : 0;
                    const offsetTop = target.getBoundingClientRect().top + window.pageYOffset - navHeight - 12;
                    window.scrollTo({
                        top: Math.max(0, offsetTop),
                        behavior: 'smooth'
                    });
                });
            });
        })();
    </script>
}
