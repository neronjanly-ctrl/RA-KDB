<script>
    (function () {
        const page = document.getElementById("raPage");
        const glow = document.getElementById("mouseGlow");
        const magneticCards = document.querySelectorAll(".magnetic-card");
        const rippleButtons = document.querySelectorAll(".ripple-btn");
        const jointCard = document.getElementById("jointCard");

        if (page && glow) {
            page.addEventListener("mousemove", function (e) {
                glow.style.transform = `translate(${e.clientX - glow.offsetWidth / 2}px, ${e.clientY - glow.offsetHeight / 2}px)`;
            });
        }

        magneticCards.forEach(card => {
            card.addEventListener("mousemove", function (e) {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;

                const centerX = rect.width / 2;
                const centerY = rect.height / 2;

                const moveX = (x - centerX) / centerX * 6;
                const moveY = (y - centerY) / centerY * 6;

                card.style.transform = `translate3d(${moveX}px, ${moveY}px, 0)`;
            });

            card.addEventListener("mouseleave", function () {
                card.style.transform = "translate3d(0, 0, 0)";
            });
        });

        rippleButtons.forEach(button => {
            button.addEventListener("click", function (e) {
                const ripple = document.createElement("span");
                ripple.classList.add("ripple");

                const rect = button.getBoundingClientRect();
                const size = Math.max(rect.width, rect.height);

                ripple.style.width = ripple.style.height = `${size}px`;
                ripple.style.left = `${e.clientX - rect.left - size / 2}px`;
                ripple.style.top = `${e.clientY - rect.top - size / 2}px`;

                button.appendChild(ripple);

                setTimeout(() => {
                    ripple.remove();
                }, 700);
            });
        });

        if (jointCard) {
            jointCard.addEventListener("mousemove", function (e) {
                const rect = jointCard.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;

                const rotateY = ((x / rect.width) - 0.5) * 5;
                const rotateX = ((y / rect.height) - 0.5) * -5;

                jointCard.style.transform = `perspective(1200px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translate3d(0,0,0)`;
            });

            jointCard.addEventListener("mouseleave", function () {
                jointCard.style.transform = "perspective(1200px) rotateX(0deg) rotateY(0deg)";
            });
        }
    })();
</script>
