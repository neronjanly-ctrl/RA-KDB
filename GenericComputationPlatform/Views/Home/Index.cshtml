@{
    ViewData["Title"] = "Rheumatoid Arthritis Research";
}

<section class="ra-page" id="raPage">
    <div class="mouse-glow" id="mouseGlow"></div>
    <div class="hero-grid-overlay"></div>

    <section class="hero-section">
        <div class="hero-content">
            <div class="hero-badge">Rheumatoid Arthritis Research Platform</div>

            <h1 class="hero-title">
                Advancing Research in
                <span>Rheumatoid Arthritis</span>
            </h1>

            <p class="hero-subtitle">
                探索炎症机制、免疫网络、关节损伤进展与临床生物标志物，
                以清晰、交互化的方式呈现类风湿疾病研究的知识结构。
            </p>

            <div class="hero-actions">
                <a href="#research-focus" class="btn btn-primary ripple-btn">Explore Research</a>
                <a href="#publications" class="btn btn-secondary ripple-btn">View Publications</a>
            </div>

            <div class="hero-metrics">
                <div class="metric-card">
                    <div class="metric-value">05</div>
                    <div class="metric-label">Research Themes</div>
                </div>
                <div class="metric-card">
                    <div class="metric-value">24+</div>
                    <div class="metric-label">Selected Publications</div>
                </div>
                <div class="metric-card">
                    <div class="metric-value">12</div>
                    <div class="metric-label">Interactive Mechanism Nodes</div>
                </div>
            </div>
        </div>

        <div class="hero-visual">
            <div class="hero-visual-card magnetic-card" id="jointCard">
                <div class="visual-backdrop"></div>

                <svg class="joint-visual" viewBox="0 0 700 700" xmlns="http://www.w3.org/2000/svg" aria-label="Abstract rheumatoid arthritis joint visualization">
                    <defs>
                        <radialGradient id="softBlue" cx="50%" cy="50%" r="50%">
                            <stop offset="0%" stop-color="#dff3fb" stop-opacity="0.95" />
                            <stop offset="100%" stop-color="#f7fbfd" stop-opacity="0.1" />
                        </radialGradient>

                        <radialGradient id="warmInflammation" cx="50%" cy="50%" r="50%">
                            <stop offset="0%" stop-color="#e8877d" stop-opacity="0.55" />
                            <stop offset="100%" stop-color="#e8877d" stop-opacity="0" />
                        </radialGradient>

                        <linearGradient id="lineBlue" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#4A90E2" />
                            <stop offset="100%" stop-color="#73C7B8" />
                        </linearGradient>

                        <filter id="blurGlow">
                            <feGaussianBlur stdDeviation="16" />
                        </filter>
                    </defs>

                    <!-- soft background layers -->
                    <circle cx="360" cy="350" r="230" fill="url(#softBlue)" opacity="0.75"></circle>
                    <circle cx="475" cy="250" r="90" fill="#d8f0ee" opacity="0.55"></circle>
                    <circle cx="245" cy="455" r="75" fill="#e9f3fe" opacity="0.8"></circle>

                    <!-- layered joint-inspired forms -->
                    <g class="joint-shell">
                        <path d="M210 365
                                 C225 250, 315 190, 405 205
                                 C490 219, 548 289, 534 379
                                 C520 474, 440 525, 352 515
                                 C267 505, 195 454, 210 365Z"
                              fill="#ffffff" opacity="0.95" stroke="#dbe9f2" stroke-width="2"></path>

                        <path d="M250 363
                                 C260 286, 321 242, 394 251
                                 C458 259, 500 311, 493 383
                                 C486 448, 428 485, 363 478
                                 C297 470, 240 432, 250 363Z"
                              fill="#f8fbfc" stroke="#d8e9ee" stroke-width="2"></path>

                        <path d="M284 363
                                 C292 312, 336 278, 390 286
                                 C438 293, 469 329, 465 380
                                 C461 427, 420 456, 376 451
                                 C327 446, 279 417, 284 363Z"
                              fill="#eef8fa" stroke="#d2e6ec" stroke-width="2"></path>
                    </g>

                    <!-- inflammation zones -->
                    <g id="hotspots">
                        <circle class="hotspot hotspot-1" cx="374" cy="335" r="55" fill="url(#warmInflammation)"></circle>
                        <circle class="hotspot hotspot-2" cx="435" cy="390" r="40" fill="url(#warmInflammation)" opacity="0.6"></circle>
                        <circle class="hotspot hotspot-3" cx="314" cy="405" r="34" fill="url(#warmInflammation)" opacity="0.45"></circle>
                    </g>

                    <!-- rings -->
                    <g class="pulse-rings">
                        <circle cx="374" cy="335" r="78" fill="none" stroke="#ebb4ab" stroke-width="2" opacity="0.28"></circle>
                        <circle cx="374" cy="335" r="108" fill="none" stroke="#f0c9c2" stroke-width="1.5" opacity="0.2"></circle>
                    </g>

                    <!-- network lines -->
                    <g class="network-lines">
                        <line x1="120" y1="188" x2="255" y2="286" stroke="url(#lineBlue)" stroke-width="2" opacity="0.5" />
                        <line x1="180" y1="505" x2="303" y2="423" stroke="url(#lineBlue)" stroke-width="2" opacity="0.42" />
                        <line x1="520" y1="173" x2="448" y2="292" stroke="url(#lineBlue)" stroke-width="2" opacity="0.45" />
                        <line x1="568" y1="472" x2="460" y2="410" stroke="url(#lineBlue)" stroke-width="2" opacity="0.42" />
                        <line x1="605" y1="315" x2="475" y2="350" stroke="url(#lineBlue)" stroke-width="2" opacity="0.35" />
                    </g>

                    <!-- nodes -->
                    <g class="network-nodes">
                        <circle class="node" cx="120" cy="188" r="10" fill="#ffffff" stroke="#73C7B8" stroke-width="2"></circle>
                        <circle class="node" cx="180" cy="505" r="10" fill="#ffffff" stroke="#4A90E2" stroke-width="2"></circle>
                        <circle class="node" cx="520" cy="173" r="10" fill="#ffffff" stroke="#73C7B8" stroke-width="2"></circle>
                        <circle class="node" cx="568" cy="472" r="10" fill="#ffffff" stroke="#4A90E2" stroke-width="2"></circle>
                        <circle class="node" cx="605" cy="315" r="10" fill="#ffffff" stroke="#A7A4D5" stroke-width="2"></circle>
                        <circle class="node active-node" cx="255" cy="286" r="8" fill="#73C7B8"></circle>
                        <circle class="node active-node" cx="303" cy="423" r="8" fill="#4A90E2"></circle>
                        <circle class="node active-node" cx="448" cy="292" r="8" fill="#73C7B8"></circle>
                        <circle class="node active-node" cx="460" cy="410" r="8" fill="#E8877D"></circle>
                        <circle class="node active-node" cx="475" cy="350" r="8" fill="#A7A4D5"></circle>
                    </g>

                    <!-- labels -->
                    <g class="visual-labels">
                        <g class="label" transform="translate(62, 160)">
                            <rect x="0" y="0" rx="12" ry="12" width="120" height="38" fill="#ffffff" opacity="0.95"></rect>
                            <text x="18" y="24" fill="#2c4b63" font-size="15" font-weight="600">Immune network</text>
                        </g>

                        <g class="label" transform="translate(500, 132)">
                            <rect x="0" y="0" rx="12" ry="12" width="112" height="38" fill="#ffffff" opacity="0.95"></rect>
                            <text x="18" y="24" fill="#2c4b63" font-size="15" font-weight="600">Synovium</text>
                        </g>

                        <g class="label" transform="translate(510, 458)">
                            <rect x="0" y="0" rx="12" ry="12" width="120" height="38" fill="#ffffff" opacity="0.95"></rect>
                            <text x="18" y="24" fill="#2c4b63" font-size="15" font-weight="600">Inflammation</text>
                        </g>
                    </g>

                    <!-- floating blur accents -->
                    <circle cx="530" cy="220" r="34" fill="#bfe4e7" opacity="0.45" filter="url(#blurGlow)"></circle>
                    <circle cx="245" cy="502" r="30" fill="#c9dcfb" opacity="0.42" filter="url(#blurGlow)"></circle>
                </svg>

                <div class="visual-legend">
                    <div class="legend-item">
                        <span class="legend-dot dot-blue"></span>
                        <span>Immune signaling</span>
                    </div>
                    <div class="legend-item">
                        <span class="legend-dot dot-green"></span>
                        <span>Synovial response</span>
                    </div>
                    <div class="legend-item">
                        <span class="legend-dot dot-coral"></span>
                        <span>Inflammatory activity</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="content-section" id="research-focus">
        <div class="section-heading">
            <span class="section-kicker">Research Focus</span>
            <h2>Key Directions in Rheumatoid Arthritis Research</h2>
            <p>
                以机制研究、疾病进展、信号通路与临床关联为核心，构建清晰的学术展示框架。
            </p>
        </div>

        <div class="focus-grid">
            <article class="focus-card magnetic-card">
                <div class="focus-icon">01</div>
                <h3>Synovial Inflammation</h3>
                <p>聚焦滑膜炎症反应、组织增生、局部微环境变化及其与疾病活动度的关系。</p>
            </article>

            <article class="focus-card magnetic-card">
                <div class="focus-icon">02</div>
                <h3>Immune Signaling</h3>
                <p>研究细胞因子网络、免疫细胞互作以及自身免疫激活过程中的关键信号节点。</p>
            </article>

            <article class="focus-card magnetic-card">
                <div class="focus-icon">03</div>
                <h3>Cartilage Damage</h3>
                <p>探讨关节软骨与骨结构损伤路径，分析炎症反应与不可逆损害之间的联系。</p>
            </article>

            <article class="focus-card magnetic-card">
                <div class="focus-icon">04</div>
                <h3>Biomarker Discovery</h3>
                <p>整合实验室指标、临床特征与分子层面数据，支持疾病分层与风险评估研究。</p>
            </article>
        </div>
    </section>

    <section class="content-section mechanism-section">
        <div class="section-heading narrow">
            <span class="section-kicker">Knowledge Map</span>
            <h2>Disease Mechanism Overview</h2>
            <p>
                从免疫激活到关节损伤，将关键过程转译为简洁、可阅读的知识路径。
            </p>
        </div>

        <div class="mechanism-map">
            <div class="mechanism-node magnetic-card">
                <span class="node-tag">01</span>
                <h3>Immune Activation</h3>
                <p>自身免疫反应驱动异常炎症信号的产生。</p>
            </div>
            <div class="mechanism-link"></div>
            <div class="mechanism-node magnetic-card">
                <span class="node-tag">02</span>
                <h3>Synovial Hyperplasia</h3>
                <p>滑膜增生与局部炎性微环境持续放大。</p>
            </div>
            <div class="mechanism-link"></div>
            <div class="mechanism-node magnetic-card">
                <span class="node-tag">03</span>
                <h3>Cytokine Pathways</h3>
                <p>多种细胞因子共同参与炎症维持与传播。</p>
            </div>
            <div class="mechanism-link"></div>
            <div class="mechanism-node magnetic-card">
                <span class="node-tag">04</span>
                <h3>Joint Damage</h3>
                <p>长期炎症导致软骨、骨和功能层面的损害。</p>
            </div>
        </div>
    </section>

    <section class="content-section" id="publications">
        <div class="section-heading">
            <span class="section-kicker">Selected Publications</span>
            <h2>Recent Findings and Academic Outputs</h2>
            <p>
                用更清晰的方式展示论文、关键词和研究主题的关联。
            </p>
        </div>

        <div class="publication-grid">
            <article class="publication-card magnetic-card">
                <div class="publication-year">2026</div>
                <h3>Synovial Immune Dynamics in Early Rheumatoid Arthritis</h3>
                <p class="publication-meta">Journal of Translational Immunology</p>
                <div class="publication-tags">
                    <span>Synovium</span>
                    <span>Immune response</span>
                    <span>Early RA</span>
                </div>
            </article>

            <article class="publication-card magnetic-card">
                <div class="publication-year">2025</div>
                <h3>Cytokine Signaling Patterns and Structural Joint Damage</h3>
                <p class="publication-meta">Clinical Rheumatology Research</p>
                <div class="publication-tags">
                    <span>Cytokines</span>
                    <span>Cartilage</span>
                    <span>Progression</span>
                </div>
            </article>

            <article class="publication-card magnetic-card">
                <div class="publication-year">2025</div>
                <h3>Biomarker Stratification for Inflammatory Disease Activity</h3>
                <p class="publication-meta">Immunology & Biomarker Systems</p>
                <div class="publication-tags">
                    <span>Biomarkers</span>
                    <span>Disease activity</span>
                    <span>Clinical data</span>
                </div>
            </article>
        </div>
    </section>

    <section class="content-section team-section">
        <div class="team-panel magnetic-card">
            <div class="team-copy">
                <span class="section-kicker">Research Platform</span>
                <h2>Built for Academic Clarity and Exploratory Insight</h2>
                <p>
                    面向研究团队、专题项目与学术平台的展示场景，以清晰结构、明亮医学视觉和轻量交互反馈，
                    支持疾病机制、成果输出与合作信息的统一表达。
                </p>

                <div class="hero-actions">
                    <a href="#" class="btn btn-primary ripple-btn">Access Platform</a>
                    <a href="#" class="btn btn-secondary ripple-btn">Contact Group</a>
                </div>
            </div>

            <div class="team-side">
                <div class="mini-stat">
                    <strong>Immune</strong>
                    <span>Pathways</span>
                </div>
                <div class="mini-stat">
                    <strong>Clinical</strong>
                    <span>Correlation</span>
                </div>
                <div class="mini-stat">
                    <strong>Mechanism</strong>
                    <span>Visualization</span>
                </div>
            </div>
        </div>
    </section>
</section>

<style>
    :root {
        --bg-main: #f8fbfc;
        --bg-soft: #f5f9fa;
        --bg-card: rgba(255, 255, 255, 0.82);
        --line-soft: rgba(95, 142, 174, 0.14);
        --text-main: #18354b;
        --text-soft: #567188;
        --text-muted: #7b93a6;
        --blue: #4A90E2;
        --cyan: #5BAFCF;
        --green: #73C7B8;
        --coral: #E8877D;
        --purple: #A7A4D5;
        --sand: #E8DCC8;
        --shadow-lg: 0 20px 60px rgba(90, 128, 155, 0.14);
        --shadow-md: 0 14px 36px rgba(90, 128, 155, 0.10);
        --radius-xl: 28px;
        --radius-lg: 20px;
        --radius-md: 16px;
        --transition-soft: 0.35s ease;
    }

    * {
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        background: radial-gradient(circle at top left, rgba(115, 199, 184, 0.08), transparent 28%), radial-gradient(circle at top right, rgba(74, 144, 226, 0.08), transparent 25%), linear-gradient(180deg, #fbfdff 0%, #f7fbfc 100%);
        color: var(--text-main);
        font-family: "Inter", "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
    }

    .ra-page {
        position: relative;
        overflow: hidden;
        min-height: 100vh;
        padding: 36px 0 80px;
        background: radial-gradient(circle at 20% 20%, rgba(115, 199, 184, 0.06), transparent 20%), radial-gradient(circle at 80% 15%, rgba(74, 144, 226, 0.06), transparent 20%), linear-gradient(180deg, var(--bg-main) 0%, #fbfdff 100%);
    }

    .mouse-glow {
        position: fixed;
        top: 0;
        left: 0;
        width: 340px;
        height: 340px;
        border-radius: 50%;
        pointer-events: none;
        z-index: 0;
        background: radial-gradient(circle, rgba(91, 175, 207, 0.12) 0%, rgba(115, 199, 184, 0.09) 35%, rgba(255,255,255,0) 70%);
        transform: translate(-50%, -50%);
        transition: transform 0.08s linear;
        filter: blur(10px);
        opacity: 1;
    }

    .hero-grid-overlay {
        position: absolute;
        inset: 0;
        z-index: 0;
        opacity: 0.32;
        pointer-events: none;
        background-image: linear-gradient(rgba(108, 149, 180, 0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(108, 149, 180, 0.08) 1px, transparent 1px);
        background-size: 48px 48px;
        mask-image: linear-gradient(to bottom, rgba(0,0,0,0.28), rgba(0,0,0,0));
    }

    .hero-section,
    .content-section {
        position: relative;
        z-index: 1;
        width: min(1200px, calc(100% - 48px));
        margin: 0 auto;
    }

    .hero-section {
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: 42px;
        align-items: center;
        min-height: calc(100vh - 120px);
        padding: 24px 0 36px;
    }

    .hero-content {
        animation: fadeUp 0.8s ease both;
    }

    .hero-badge,
    .section-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid rgba(108, 149, 180, 0.14);
        color: var(--cyan);
        font-size: 0.88rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        box-shadow: 0 8px 22px rgba(87, 130, 160, 0.06);
        backdrop-filter: blur(10px);
    }

    .hero-title {
        margin: 22px 0 18px;
        font-size: clamp(2.8rem, 5vw, 5.2rem);
        line-height: 1.06;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--text-main);
        max-width: 720px;
    }

        .hero-title span {
            display: inline-block;
            color: var(--blue);
            position: relative;
        }

            .hero-title span::after {
                content: "";
                position: absolute;
                left: 0;
                right: 0;
                bottom: 8px;
                height: 16px;
                background: rgba(115, 199, 184, 0.16);
                z-index: -1;
                border-radius: 999px;
            }

    .hero-subtitle {
        max-width: 640px;
        color: var(--text-soft);
        font-size: 1.08rem;
        line-height: 1.9;
        margin-bottom: 28px;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 30px;
    }

    .btn {
        position: relative;
        overflow: hidden;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 50px;
        padding: 0 22px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.98rem;
        transition: transform 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
        border: 1px solid transparent;
        will-change: transform;
    }

        .btn:hover {
            transform: translateY(-2px);
        }

    .btn-primary {
        color: #fff;
        background: linear-gradient(135deg, var(--blue), var(--cyan));
        box-shadow: 0 12px 28px rgba(74, 144, 226, 0.24);
    }

    .btn-secondary {
        color: var(--text-main);
        background: rgba(255,255,255,0.82);
        border-color: rgba(108, 149, 180, 0.16);
        box-shadow: 0 10px 24px rgba(84, 120, 149, 0.08);
        backdrop-filter: blur(10px);
    }

    .hero-metrics {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
        max-width: 760px;
    }

    .metric-card {
        padding: 18px 18px;
        border-radius: var(--radius-md);
        background: rgba(255,255,255,0.78);
        border: 1px solid rgba(108, 149, 180, 0.12);
        box-shadow: 0 12px 26px rgba(84, 120, 149, 0.06);
        backdrop-filter: blur(10px);
    }

    .metric-value {
        font-size: 1.65rem;
        font-weight: 800;
        color: var(--text-main);
        margin-bottom: 6px;
    }

    .metric-label {
        font-size: 0.92rem;
        color: var(--text-muted);
        line-height: 1.5;
    }

    .hero-visual {
        animation: fadeUp 1s ease 0.12s both;
    }

    .hero-visual-card {
        position: relative;
        border-radius: 34px;
        padding: 24px;
        background: linear-gradient(180deg, rgba(255,255,255,0.82), rgba(255,255,255,0.66));
        border: 1px solid rgba(116, 153, 181, 0.15);
        box-shadow: var(--shadow-lg);
        backdrop-filter: blur(12px);
        transform-style: preserve-3d;
        transition: transform 0.22s ease, box-shadow 0.22s ease;
    }

    .visual-backdrop {
        position: absolute;
        inset: 18px;
        border-radius: 28px;
        background: radial-gradient(circle at 70% 30%, rgba(115, 199, 184, 0.11), transparent 20%), radial-gradient(circle at 32% 72%, rgba(74, 144, 226, 0.10), transparent 22%), linear-gradient(180deg, rgba(244,250,252,0.96), rgba(248,251,252,0.78));
        pointer-events: none;
    }

    .joint-visual {
        position: relative;
        z-index: 1;
        width: 100%;
        height: auto;
        display: block;
    }

    .hotspot,
    .pulse-rings circle,
    .network-nodes .node,
    .network-lines line,
    .visual-labels .label {
        transition: transform 0.35s ease, opacity 0.35s ease, filter 0.35s ease;
        transform-origin: center;
    }

    .hero-visual-card:hover .hotspot-1 {
        transform: scale(1.08);
        opacity: 0.9;
    }

    .hero-visual-card:hover .hotspot-2 {
        transform: scale(1.14);
        opacity: 0.82;
    }

    .hero-visual-card:hover .hotspot-3 {
        transform: scale(1.12);
        opacity: 0.76;
    }

    .hero-visual-card:hover .pulse-rings circle {
        opacity: 0.36;
        transform: scale(1.04);
    }

    .hero-visual-card:hover .network-nodes .node {
        transform: translateY(-2px);
    }

    .hero-visual-card:hover .visual-labels .label {
        transform: translateY(-3px);
    }

    .visual-legend {
        position: relative;
        z-index: 1;
        margin-top: 8px;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .legend-item {
        display: inline-flex;
        align-items: center;
        gap: 8px;
