@model TargetListModel
@inject IOptions<AppSettings> _appSettings
@{
    var propFields = _appSettings.Value.TargetList.PropFields;
    if (Model.TagName == null)
        ViewData["Title"] = "Protein Targets";
    else
        ViewData["Title"] = $"Protein Targets - {Model.TagName}";
}
<h2>@ViewData["Title"]</h2>

@if (Model.HasDocument)
{
    <div class="small text-muted mb-2">
        <span class="bg-info mr-2">&nbsp;</span>
        <span>
            Alternately, the targets and drugs in Word document (.docx) can also be downloaded <a href="~/@(Model.Domain.Id).docx">here</a>.
        </span>
    </div>
}

<hr />

<table class="table table-striped table-hover table-maxwidth mt-3 w-100">
    <thead>
        <tr>
            <th scope="col">Protein</th>
            <th scope="col">Protein name</th>
            <th scope="col">Organism</th>
            <th scope="col">Symbol</th>
            <th scope="col">Gene</th>
            @foreach (var field in propFields)
            {
                <th scope="col">@field</th>
            }
            <th scope="col">Compounds</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cavity in Model.Targets.SelectMany(o => o.Cavities))
        {
            var protein = cavity.Protein;
            <tr>
                <th scope="row"><img style="width:102.4px" src="~/images/s/@(cavity.ProteinId)-@(cavity.BindingSite)-model_1.png" alt="" /></th>
                <td>
                    <a data-toggle="modal" data-target="#proteinInfo" data-proteinId="@protein.Id"
                       asp-controller="Protein" asp-action="Details" asp-route-domainId="@Model.Domain.Id" asp-route-cavityId="@cavity.Id.StringifyId()">
                        @protein.ProteinName
                        <i class="fas fa-external-link-alt"></i>
                    </a>
                </td>
                <td>@protein.Organism.Replace(";", "; ")</td>
                <td>
                    @(protein.ProteinSymbol)_@(protein.OrganismSymbol)
                </td>
                <td>@protein.GeneSymbol</td>
                @foreach (var field in propFields)
                {
                    <td>
                        @switch (field.ToLower())
                        {
                            case "uniprot":
                                @if (protein.Properties.UniProt != null)
                                {
                                    <a class="text-nowrap" target="_blank" href="@protein.Properties.UniProt.Url">@protein.Properties.UniProt.Id <i class="fas fa-external-link-alt"></i></a>
                                }
                                break;
                            case "chembl":
                                @if (protein.Properties.Chembl != null)
                                {
                                    <a class="text-nowrap" target="_blank" href="@protein.Properties.Chembl.TargetUrl">@protein.Properties.Chembl.Id <i class="fas fa-external-link-alt"></i></a>
                                }
                                break;
                            case "ensembl":
                                @if (protein.Properties.Ensembl != null)
                                {
                                    <a class="text-nowrap" target="_blank" href="@protein.Properties.Ensembl.Url">@protein.Properties.Ensembl.Id <i class="fas fa-external-link-alt"></i></a>
                                }
                                break;
                            case "genbank":
                                @if (protein.Properties.GenBank != null)
                                {
                                    <a class="text-nowrap" target="_blank" href="@protein.Properties.GenBank.Url">@protein.Properties.GenBank.Id <i class="fas fa-external-link-alt"></i></a>
                                }
                                break;
                            case "ncbi":
                            case "refseq":
                                @if (protein.Properties.Ncbi != null)
                                {
                                    <a class="text-nowrap" target="_blank" href="@protein.Properties.Ncbi.RefSeqUrl">@protein.Properties.Ncbi.Id <i class="fas fa-external-link-alt"></i></a>
                                }
                                break;
                            case "hgnc":
                            case "genename":
                                @if (protein.Properties.Hgnc != null)
                                {
                                    <a class="text-nowrap" target="_blank" href="@protein.Properties.Hgnc.GeneNamesUrl">HGNC:@protein.Properties.Hgnc.Id <i class="fas fa-external-link-alt"></i></a>
                                }
                                break;
                            default:
                                break;
                        }
                    </td>
                }
                <td>
                    @if (protein.BioactivityCount != 0 || protein.RawBioactivityCount != 0)
                    {
                        <a class="text-nowrap" target="_blank" href="https://www.ebi.ac.uk/chembl/g/#browse/activities/filter/target_chembl_id%3A@(protein.Properties.Chembl.Id)" title="@protein.BioactivityCount ChEMBL bioactivities, @protein.RawBioactivityCount ChEMBL compounds">@protein.BioactivityCount / @protein.RawBioactivityCount <i class="fas fa-external-link-alt"></i></a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Protein Info Modal -->
<div class="modal fade" id="proteinInfo" tabindex="-1" role="dialog" aria-labelledby="proteinName" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="proteinName"></h5>
                <div class="text-nowrap col-auto">
                    <a class="close ml-2" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </a>
                    <a href="" target="_blank" class="close maximizeBtn">
                        <span aria-hidden="true"><i class="fa fa-window-maximize"></i></span>
                    </a>
                </div>
            </div>
            <div class="modal-body">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Menu {
    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-route-domainId="@Model.Domain.Id">Home</a></li>
    <li class="nav-item">
        <a class="nav-link" asp-controller="Job" asp-action="List" asp-route-domainId="@Model.Domain.Id">
            All Jobs
            <span class="badge badge-light">@Model.RunningCount</span>
        </a>
    </li>
    <li class="nav-item active"><a class="nav-link" asp-controller="Home" asp-action="Targets" asp-route-domainId="@Model.Domain.Id" asp-route-tagId="">Targets</a></li>
    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Help" asp-route-domainId="@Model.Domain.Id">Help</a></li>
}

@section Styles {
    <environment include="Development">
        <link rel="stylesheet" href="~/lib/datatables.net-bs4/css/dataTables.bootstrap4.css" />
    </environment>
    <environment exclude="Development">
        <link rel="stylesheet" href="~/lib/datatables.net-bs4/css/dataTables.bootstrap4.min.css" />
    </environment>
}

@section Scripts {
    <environment include="Development">
        <script src="~/lib/datatables.net/jquery.dataTables.js"></script>
        <script src="~/lib/datatables.net-bs4/js/dataTables.bootstrap4.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/lib/datatables.net/jquery.dataTables.min.js"></script>
        <script src="~/lib/datatables.net-bs4/js/dataTables.bootstrap4.min.js"></script>
    </environment>
    <script src="~/lib/ngl/ngl.js"></script>
    <script>
        setupProteinInfoModal();
        $.fn.dataTable.ext.order["dom-float"] = function (settings, col) {
            return this.api().column(col, { order: "index" }).nodes().map(function (td, i) {
                const txt = $(td).text().trim();
                return txt.match(/\d+/) ? parseFloat(txt) : Infinity;
            });
        };

        $.fn.dataTable.ext.order["dom-int-tail"] = function (settings, col) {
            return this.api().column(col, { order: "index" }).nodes().map(function (td, i) {
                const txt = $(td).text().match(/\d+/);
                return txt ? parseInt(txt) : Infinity;
            });
        };

        $(() => $("table").DataTable({
            "pageLength": 50,
            "lengthMenu": [[20, 50, 100, -1], [20, 50, 100, "All"]],
            "columns": [
                { "orderable": false },
                null,
                null,
                null,
                null,
                @foreach (var field in propFields)
                {
                    @:null,
                }
                { "orderDataType": "dom-int-tail", "type": "numberic" },
            ],
            "order": [],
        }));
    </script>
}
