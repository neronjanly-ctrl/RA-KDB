@model JobListModel
@inject IOptions<AppSettings> _appSettings
@{
    ViewData["Title"] = "My Computation Jobs";
    int badge = Model.RunningCount, pc = Model.PageCount, pn = Model.PageNum;
    double jobFailureThreshold = _appSettings.Value.Options.JobFailureThreshold;
}

<div class="row mb-2">
    <h2 class="col-auto mr-auto">
        @ViewData["Title"]
        <small class="text-muted">(@badge running)</small>
    </h2>
    <div class="col-auto">
        <a class="btn btn-warning" asp-controller="Job" asp-action="New" asp-route-domainId="@Model.DomainId">Create a new job</a>
    </div>
</div>

<table class="table table-striped table-hover">
    <caption class="sr-only">List of jobs</caption>
    <thead>
        <tr>
            <th scope="col">Job</th>
            <th scope="col">Domains</th>
            <th scope="col">Ligands</th>
            <th scope="col">Created Time</th>
            <th scope="col">Updated Time</th>
            <th scope="col">Progress</th>
            <th scope="col">Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var job in Model.Jobs)
        {
            string tclass, status = job.Status.ToString();
            var domains = job.GetDomains();

            if (job.Status == RunningStatus.Failed)
            {
                if (job.Progress >= jobFailureThreshold)
                {
                    status = "Finished with Errors";
                    tclass = "text-warning2";
                }
                else
                {
                    tclass = "text-danger";
                }
            }
            else if (job.Status == RunningStatus.Finished)
            {
                tclass = "text-success";
            }
            else
            {
                tclass = "text-primary";
            }

            <tr class="@tclass">
                <th scope="row">
                    @if (domains.Length > 0)
                    {
                        foreach (var domain in domains)
                        {
                            <a asp-controller="Job" asp-action="Details" asp-route-domainId="@domain.Id" asp-route-jobId="@job.Id">
                                #@job.Id @job.Name (@domain.Id.ToUpper())
                                @if (job.IsPrivate)
                                {
                                    <i class="fas fa-lock-open text-primary"></i>
                                }
                            </a>
                        }
                    }
                    else
                    {
                        <span>
                            #@job.Id @job.Name
                            @if (job.IsPrivate)
                            {
                                <i class="fas fa-lock-open text-primary"></i>
                            }
                        </span>
                    }
                </th>
                <th scope="row">
                    @foreach (var domain in domains)
                    {
                        <a asp-controller="Home" asp-action="Index" asp-route-domainId="@domain.Id">@domain.Id.ToUpper()</a>
                    }
                </th>
                <td>@job.LigandCount: @string.Join("; ", job.JobLigands.Select(o => o.LigandName))</td>
                <td class="update-utms" data-utms="@job.Created.UtcToUnixTimeMilliseconds()"></td>
                <td class="update-utms" data-utms="@job.Updated.UtcToUnixTimeMilliseconds()"></td>
                <td>@job.Progress.ToString("P")</td>
                <td>@status</td>
            </tr>
        }
    </tbody>
</table>

<nav aria-label="Job list pagination">
    <ul class="pagination justify-content-end">
        <li class="page-item@(pn > 1 ? "" : " disabled")">
            <a class="page-link" asp-controller="User" asp-action="MyJobs" asp-route-domainId="@Model.DomainId" asp-route-pageNum="@(pn - 1)" aria-label="Previous">
                <span aria-hidden="true">&laquo;</span>
                <span class="sr-only">Previous</span>
            </a>
        </li>
        @for (var i = 1; i <= pc; i++)
        {
            if (i == pn)
            {
                <li class="page-item active">
                    <a class="page-link" asp-controller="User" asp-action="MyJobs" asp-route-domainId="@Model.DomainId" asp-route-pageNum="@i">
                        @i
                        <span class="sr-only">(current)</span>
                    </a>
                </li>
            }
            else
            {
                <li class="page-item">
                    <a class="page-link" asp-controller="User" asp-action="MyJobs" asp-route-domainId="@Model.DomainId" asp-route-pageNum="@i">@i</a>
                </li>
            }
        }
        <li class="page-item@(pn < pc ? "" : " disabled")">
            <a class="page-link" asp-controller="User" asp-action="MyJobs" asp-route-domainId="@Model.DomainId" asp-route-pageNum="@(pn + 1)" aria-label="Next">
                <span aria-hidden="true">&raquo;</span>
                <span class="sr-only">Next</span>
            </a>
        </li>
    </ul>
</nav>

@section Menu {
<li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-route-domainId="@Model.DomainId">Home</a></li>
<li class="nav-item"><a class="nav-link" asp-controller="Job" asp-action="List" asp-route-domainId="@Model.DomainId">All Jobs</a></li>
<li class="nav-item bg-dark active"><a class="nav-link" asp-controller="User" asp-action="MyJobs" asp-route-domainId="@Model.DomainId" asp-route-pageNum="1">Targets</a></li>
<li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Targets" asp-route-domainId="@Model.DomainId">Targets</a></li>
<li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Help" asp-route-domainId="@Model.DomainId">Help</a></li>
}