@inject IOptions<AppSettings> _appSettings
@inject IWebHostEnvironment _env
@{
    var title = ViewData["Title"] as string;
    var appName = _appSettings.Value.Manifest.AppName;

    var domainId = ViewContext.RouteData.Values["domainId"]?.ToString();
    if (string.IsNullOrWhiteSpace(domainId))
    {
        domainId = ViewData["DomainId"]?.ToString();
    }

    bool hasDomainContext = !string.IsNullOrWhiteSpace(domainId);

    if (string.IsNullOrWhiteSpace(title))
    {
        title = hasDomainContext ? $"{appName}: {domainId!.ToUpper()}" : appName;
    }
    else if (hasDomainContext)
    {
        title = $"{title} - {domainId!.ToUpper()}";
    }
    else
    {
        title = $"{title} - {appName}";
    }

    var keywords = ViewBag.Keywords as string[] ?? new string[0];

    string fallbackLogoId = _appSettings.Value.Branding?.DefaultLogoId;
    if (string.IsNullOrWhiteSpace(fallbackLogoId) ||
        !System.IO.File.Exists(System.IO.Path.Combine(_env.WebRootPath, "logos", $"{fallbackLogoId}.png")))
    {
        fallbackLogoId = "default";
    }

    var logoId = hasDomainContext &&
                 System.IO.File.Exists(System.IO.Path.Combine(_env.WebRootPath, "logos", $"{domainId}.png"))
        ? domainId
        : fallbackLogoId;

    string navbarBackgroundColor = string.IsNullOrWhiteSpace(_appSettings.Value.Branding?.NavbarBackgroundColor)
        ? "#F3F4F6"
        : _appSettings.Value.Branding.NavbarBackgroundColor;

    string navbarBorderColor = string.IsNullOrWhiteSpace(_appSettings.Value.Branding?.NavbarBorderColor)
        ? "#E3E6EA"
        : _appSettings.Value.Branding.NavbarBorderColor;

    var baseUri = new Uri(_appSettings.Value.ExternalUrls.Hosting.TrimEnd('/'));
    var fullUri = new Uri(baseUri, baseUri.AbsolutePath.TrimEnd('/') + Context.Request.Path.Value);
    var path = baseUri.PathAndQuery.TrimEnd('/');
    var homeAction = hasDomainContext ? "Index" : "PlatformIndex";

    var partnerLogos = (_appSettings.Value.Branding?.PartnerLogos ?? Array.Empty<PartnerLogoSettings>())
        .Where(item => !string.IsNullOrWhiteSpace(item?.Image))
        .ToArray();

    var footerEmail = _appSettings.Value.ContactEmails?.FirstOrDefault(email => !string.IsNullOrWhiteSpace(email))
        ?? "xieccgs@gmail.com and yuanone011@gmail.com";

    var footerAddress = new[]
    {
        _appSettings.Value.Manifest.Address,
    }
    .Where(line => !string.IsNullOrWhiteSpace(line))
    .ToArray();
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@title</title>

    <meta name="keywords" content="@string.Join(",", keywords)" />
    <meta name="description" content="@_appSettings.Value.Manifest.Description" />
    <meta name="author" content="One Blue" />
    <meta property="og:title" content="@title - From RA_SUAT" />
    <meta property="og:image" content="@baseUri.AbsolutePath/logos/@(logoId)-sharing.png" />
    <meta property="og:description" content="@_appSettings.Value.Manifest.Description" />

    <link rel="canonical" href="@fullUri" />
    <link rel="manifest" href="~/manifest.json" />
    <meta name="msapplication-TileColor" content="#ffffff" />
    <meta name="msapplication-TileImage" content="@path/ms-icon-144x144.png" />
    <meta name="theme-color" content="#ffffff" />

    <environment include="Development">
        <link rel="stylesheet" href="~/lib/@("@fortawesome")/css/all.css" />
        <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.css" />
        <link rel="stylesheet" href="~/css/site.css" />
    </environment>
    <environment exclude="Development">
        <link rel="stylesheet"
              href="https://use.fontawesome.com/releases/v5.3.1/css/all.css"
              asp-fallback-href="~/lib/@("@fortawesome")/css/all.css"
              asp-fallback-test-class="fa" />
        <link rel="stylesheet"
              href="https://stackpath.bootstrapcdn.com/bootstrap/4.1.3/css/bootstrap.min.css"
              asp-fallback-href="~/lib/bootstrap/css/bootstrap.min.css"
              asp-fallback-test-class="sr-only"
              asp-fallback-test-property="position"
              asp-fallback-test-value="absolute" />
        <link rel="stylesheet" href="~/css/site.min.css" asp-append-version="true" />
    </environment>

    @RenderSection("Styles", false)

    <style>
    .navbar.site-navbar {
        min-height: 84px;
        padding: 0;
        border-bottom-width: 1px;
        border-bottom-style: solid;
        background: transparent;
    }

    .site-navbar .container {
        display: flex;
        align-items: center;
        padding-left: 6px;
        padding-right: 20px;
    }

    .site-navbar .navbar-brand.brand-lockup {
        display: inline-flex;
        align-items: center;
        gap: 14px;
        margin: 0 1rem 0 0;
        padding: 0;
        min-height: 72px;
        height: 84px;
        line-height: 1;
        text-decoration: none;
        flex-shrink: 0;
    }

    .site-navbar .brand-lockup-logo {
        display: block;
        max-height: 52px;
        max-width: 240px;
        width: auto;
        height: auto;
        object-fit: contain;
        flex-shrink: 0;
    }

    .site-navbar .brand-lockup-divider {
        width: 1px;
        height: 40px;
        background: #C9CDD3;
        flex-shrink: 0;
    }

    .site-navbar .brand-lockup-text {
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-width: 0;
    }

    .site-navbar .brand-lockup-line1 {
        font-size: 1.08rem;
        font-weight: 600;
        color: #2F3440;
        white-space: nowrap;
    }

    .site-navbar .brand-lockup-line2 {
        margin-top: 4px;
        font-size: 0.92rem;
        font-weight: 500;
        color: #4B5563;
        white-space: nowrap;
    }

    .site-navbar .navbar-nav {
        align-items: center;
    }

    .site-navbar .navbar-nav .nav-item,
    .site-navbar .navbar-nav .nav-link {
        color: #2F3440;
        font-weight: 700;
        font-size: 1rem;
        text-transform: none;
    }

    .site-navbar .navbar-nav .nav-link {
        background: transparent;
    }

    .site-navbar .navbar-nav .nav-link:hover,
    .site-navbar .navbar-nav .nav-link:focus {
        color: #6F42C1;
    }

    .site-navbar .navbar-nav .workspace-nav-item .nav-link {
        display: inline-flex;
        align-items: center;
    }

    .site-navbar .navbar-nav .workspace-nav-item + .workspace-nav-item .nav-link::before,
    .site-navbar .site-auth-link-with-separator::before {
        content: "|";
        color: #8B93A3;
        font-weight: 500;
        margin: 0 .85rem 0 .15rem;
    }

    .site-navbar .site-auth-link {
        color: #2F3440;
        font-weight: 700;
        font-size: 1rem;
        text-transform: none;
        text-decoration: none;
        padding: .5rem .25rem;
        background: transparent;
        border: 0;
        box-shadow: none;
    }

    .site-navbar .site-auth-link:hover,
    .site-navbar .site-auth-link:focus {
        color: #6F42C1;
        text-decoration: none;
    }

    .site-navbar .site-auth-link .fas {
        margin-left: .25rem;
        color: inherit;
    }

    @@media (max-width: 991.98px) {
        .site-navbar .navbar-brand.brand-lockup {
            gap: 10px;
        }

        .site-navbar .brand-lockup-logo {
            max-height: 44px;
            max-width: 180px;
        }

        .site-navbar .brand-lockup-divider {
            height: 34px;
        }

        .site-navbar .brand-lockup-line1 {
            font-size: 0.98rem;
        }

        .site-navbar .brand-lockup-line2 {
            font-size: 0.82rem;
        }
    }

    @@media (max-width: 767.98px) {
        .site-navbar .brand-lockup-divider,
        .site-navbar .brand-lockup-text {
            display: none;
        }

        .site-navbar .container {
            padding-left: 12px;
            padding-right: 12px;
        }
    }

    .site-footer {
        margin-top: 36px;
        padding: 0 0 28px;
    }

    .site-footer-panel {
        border-top: 1px solid #E3E8EF;
        padding: 28px 0 0;
    }

    .site-footer-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 32px;
        padding: 0 0 18px;
    }

    .site-footer-logos {
        display: flex;
        align-items: center;
        gap: 18px;
        flex: 1 1 auto;
        min-width: 0;
        flex-wrap: wrap;
    }

    .site-footer-logo-card {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 86px;
        padding: 10px 18px;
        border-radius: 14px;
        background: #FFFFFF;
        border: 1px solid #E5EAF1;
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.04);
        text-decoration: none;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    .site-footer-logo-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px rgba(15, 23, 42, 0.08);
        text-decoration: none;
    }

    .site-footer-logo {
        display: block;
        max-width: 180px;
        max-height: 58px;
        width: auto;
        height: auto;
        object-fit: contain;
    }

    .site-footer-contact {
        flex: 0 0 360px;
        color: #4B5563;
        line-height: 1.7;
    }

    .site-footer-contact h5 {
        margin: 0 0 12px;
        font-size: 1.45rem;
        font-weight: 700;
        color: #111827;
    }

    .site-footer-contact p {
        margin: 0 0 6px;
    }

    .site-footer-contact a {
        color: #2563EB;
    }

    .site-footer-bottom {
        text-align: center;
        color: #6B7280;
        font-size: 0.98rem;
        padding-top: 10px;
    }

    @@media (max-width: 991.98px) {
        .site-footer-top {
            flex-direction: column;
            align-items: flex-start;
        }

        .site-footer-contact {
            flex-basis: auto;
        }
    }

    @@media (max-width: 575.98px) {
        .site-footer-logo-card {
            width: 100%;
        }

        .site-footer-logo {
            max-width: 100%;
        }
    }
</style>
</head>
<body>
    <nav class="navbar sticky-top navbar-expand navbar-light mb-4 site-navbar"
         style="background-color:@navbarBackgroundColor; border-bottom-color:@navbarBorderColor;">
        <div class="container">
            <a asp-controller="Home"
               asp-action="PlatformIndex"
               class="navbar-brand brand-lockup">
                <img alt="@appName" src="~/logos/@(logoId).png" class="brand-lockup-logo" />
                <span class="brand-lockup-divider" aria-hidden="true"></span>
                <span class="brand-lockup-text">
                    <span class="brand-lockup-line1">类风湿关节炎知识与对接平台</span>
                    <span class="brand-lockup-line2">Rheumatoid Arthritis Knowledge & Docking Platform</span>
                </span>
            </a>

            <div class="collapse navbar-collapse text-nowrap justify-content-end" id="navbarMenu">
                <ul class="navbar-nav ml-auto">
                    @RenderSection("Menu", false)
                </ul>
            </div>

            @if (User.Identity.IsAuthenticated)
            {
                var email = User.GetEmail();
                var userId = User.GetUserId();
                string loginHint = email == userId
                ? email
                : $"ID: {userId}\nEmail: {email}";

                <div class="dropdown">
                    <a class="btn btn-secondary btn-light dropdown-toggle"
                       href=""
                       title="@loginHint"
                       role="button"
                       id="dropdownMenuLink"
                       data-toggle="dropdown"
                       aria-haspopup="true"
                       aria-expanded="false">
                        @User.GetName()
                        <i class="fas fa-user"></i>
                    </a>
                    <div class="dropdown-menu" aria-labelledby="dropdownMenuLink">
                        <a class="dropdown-item"
                           asp-controller="User"
                           asp-action="MyJobs"
                           asp-route-domainId="@domainId"
                           asp-route-pageNum="1">
                            My jobs
                        </a>
                        <a class="dropdown-item"
                           asp-controller="User"
                           asp-action="LogOut"
                           asp-route-redirectUrl="@Context.Request.Path.Value">
                            Sign out
                        </a>
                    </div>
                </div>
            }
            else
            {
                <a class="site-auth-link site-auth-link-with-separator"
                   title="Sign in with your Microsoft work, school, or personal account"
                   asp-controller="User"
                   asp-action="LogIn"
                   asp-route-redirectUrl="@Context.Request.Path.Value">
                    Sign In
                    <i class="fas fa-user"></i>
                </a>
            }
        </div>
    </nav>

    <partial name="_CookieConsentPartial" />

    <div class="container">
        @RenderBody()
        <footer class="site-footer">
            <div class="container">
                <div class="site-footer-panel">
                    <div class="site-footer-top">
                        <div class="site-footer-logos" aria-label="Affiliated institutions">
                            @foreach (var item in partnerLogos)
                            {
                                if (!string.IsNullOrWhiteSpace(item.Url) && item.Url != "#")
                                {
                                    <a class="site-footer-logo-card"
                                       href="@item.Url"
                                       target="_blank"
                                       rel="noopener noreferrer"
                                       title="@item.Alt">
                                        <img class="site-footer-logo" src="~/logos/@item.Image" alt="@item.Alt" />
                                    </a>
                                }
                                else
                                {
                                    <div class="site-footer-logo-card" title="@item.Alt">
                                        <img class="site-footer-logo" src="~/logos/@item.Image" alt="@item.Alt" />
                                    </div>
                                }
                            }
                        </div>

                        <div class="site-footer-contact" id="contact">
                            <h5>Contact Us</h5>
                            <p>
                                Using Email: <a href="mailto:@footerEmail">@footerEmail</a>
                            </p>
                            <p>
                                Address:@string.Join(" ", footerAddress)
                            </p>
                        </div>
                    </div>

                    <div class="site-footer-bottom">
                        Copyright © @DateTime.UtcNow.Year - @_appSettings.Value.Manifest.CopyrightLine. All Rights Reserved
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <environment include="Development">
        <script src="~/lib/jquery/jquery.js"></script>
        <script src="~/lib/popper.js/popper.js"></script>
        <script src="~/lib/bootstrap/js/bootstrap.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/lib/jquery/jquery.min.js"></script>
        <script src="~/lib/popper.js/popper.min.js"></script>
        <script src="~/lib/bootstrap/js/bootstrap.min.js"></script>
        <script src="~/js/site.min.js" asp-append-version="true"></script>
    </environment>

    @RenderSection("Scripts", false)
</body>
</html>