@section Menu {
    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-route-domainId="@Model.DomainId">Home</a></li>
    <li class="nav-item active"><a class="nav-link" asp-controller="Job" asp-action="List" asp-route-domainId="@Model.DomainId">All Jobs</a></li>
    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Targets" asp-route-domainId="@Model.DomainId">Targets</a></li>
    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Help" asp-route-domainId="@Model.DomainId">Help</a></li>
}

@section Styles {
    <environment include="Development">
        <link rel="stylesheet" href="~/lib/datatables.net-bs4/css/dataTables.bootstrap4.css" />
    </environment>
    <environment exclude="Development">
        <link rel="stylesheet" href="~/lib/datatables.net-bs4/css/dataTables.bootstrap4.min.css" />
    </environment>
}

@section Scripts {
    <environment include="Development">
        <script src="~/lib/datatables.net/jquery.dataTables.js"></script>
        <script src="~/lib/datatables.net-bs4/js/dataTables.bootstrap4.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/lib/datatables.net/jquery.dataTables.min.js"></script>
        <script src="~/lib/datatables.net-bs4/js/dataTables.bootstrap4.min.js"></script>
    </environment>
    <script src="~/lib/ngl/ngl.js"></script>
    <script>
        $.fn.dataTable.ext.order["dom-float"] = function (settings, col) {
            return this.api().column(col, { order: "index" }).nodes().map(function (td, i) {
                const txt = $(td).text().trim();
                return txt.match(/\d+/) ? parseFloat(txt) : Infinity;
            });
        };

        $.fn.dataTable.ext.order["dom-int-tail"] = function (settings, col) {
            return this.api().column(col, { order: "index" }).nodes().map(function (td, i) {
                const txt = $(td).text().match(/\d+/);
                return txt ? parseInt(txt) : Infinity;
            });
        };

        $.fn.dataTable.ext.order["utms"] = function (settings, col) {
            return this.api().column(col, { order: "index" }).nodes().map(function (td, i) {
                return $(td).data("utms");
            });
        };

        $(() => $("table").DataTable({
            "pageLength": 50,
            "lengthMenu": [[20, 50, 100, -1], [20, 50, 100, "All"]],
            "columns": [
                { "orderDataType": "dom-int-tail", "type": "numberic" },
                null,
                { "orderDataType": "utms", "type": "numeric" }, // created time
                { "orderDataType": "utms", "type": "numeric" }, // updated time
                { "orderDataType": "dom-float", "type": "numeric" }, // progress
                null,
            ],
            "order": [],
        }));
    </script>
}
