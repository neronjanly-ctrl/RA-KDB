@model JobListModel
@inject IOptions<AppSettings> _appSettings
@{
    ViewData["Title"] = "Computation Jobs";
    int badge = Model.RunningCount, pc = Model.PageCount, pn = Model.PageNum;
    string userName = User.Identity.Name?.ToLower();
    double jobFailureThreshold = _appSettings.Value.Options.JobFailureThreshold;
}

<div class="row mb-2">
    <h2 class="col-auto mr-auto">
        @ViewData["Title"]
        <small class="text-muted">(@badge running)</small>
    </h2>
    <div class="col-auto">
        <a class="btn btn-warning" asp-controller="Job" asp-action="New" asp-route-domainId="@Model.DomainId">Create a new job</a>
    </div>
</div>

<table class="table table-striped table-hover">
    <caption class="sr-only">List of jobs</caption>
    <thead>
        <tr>
            <th scope="col">Job</th>
            <th scope="col">Ligands</th>
            <th scope="col">Created Time</th>
            <th scope="col">Updated Time</th>
            <th scope="col">Progress</th>
            <th scope="col">Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var job in Model.Jobs)
        {
            string tclass, status = job.Status.ToString();

            if (job.Status == RunningStatus.Failed)
            {
                if (job.Progress >= jobFailureThreshold)
                {
                    status = "Finished with Errors";
                    tclass = "text-warning2";
                }
                else
                {
                    tclass = "text-danger";
                }
            }
            else if (job.Status == RunningStatus.Finished)
            {
                tclass = "text-success";
            }
            else
            {
                tclass = "text-primary";
            }

            <tr class="@tclass">
                <th scope="row">
                    @if (job.IsPrivate && userName != job.UserId)
                    {
                        <text>
                            #@job.Id @job.Name
                            <i class="fas fa-lock"></i>
                        </text>
                    }
                    else
                    {
                        <a asp-controller="Job" asp-action="Details" asp-route-domainId="@Model.DomainId" asp-route-jobId="@job.Id">
                            #@job.Id @job.Name
                            @if (job.IsPrivate)
                            {
                                <i class="fas fa-lock-open"></i>
                            }
                        </a>
                    }
                </th>
                <td>@job.LigandCount: @(!job.IsPrivate || userName == job.UserId ? string.Join("; ", job.JobLigands.Select(o => o.LigandName)) : "***")</td>
                <td class="update-utms" data-utms="@job.Created.UtcToUnixTimeMilliseconds()"></td>
                <td class="update-utms" data-utms="@job.Updated.UtcToUnixTimeMilliseconds()"></td>
                <td>@job.Progress.ToString("P")</td>
                <td>@status</td>
            </tr>
        }
    </tbody>
</table>

