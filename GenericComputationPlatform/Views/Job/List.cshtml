@model JobListModel
@inject IOptions<AppSettings> _appSettings
@using DockingDataModels

@{
    ViewData["Title"] = "All Docking Jobs";

    string userName = User.Identity.Name?.ToLower();
    double jobFailureThreshold = _appSettings.Value.Options.JobFailureThreshold;

    int totalJobs = Model.Jobs.Count;
    int runningJobs = Model.Jobs.Count(o => o.Status == RunningStatus.Running || o.Status == RunningStatus.Created);
    int finishedJobs = Model.Jobs.Count(o => o.Status == RunningStatus.Finished);
    int failedJobs = Model.Jobs.Count(o => o.Status == RunningStatus.Failed);

    string StatusLabel(Job job)
    {
        if (job.Status == RunningStatus.Failed && job.Progress >= jobFailureThreshold)
            return "Finished with Errors";
        return job.Status.ToString();
    }

    string StatusClass(Job job)
    {
        if (job.Status == RunningStatus.Failed && job.Progress >= jobFailureThreshold)
            return "warning";
        if (job.Status == RunningStatus.Failed)
            return "danger";
        if (job.Status == RunningStatus.Finished)
            return "success";
        if (job.Status == RunningStatus.Running)
            return "primary";
        return "secondary";
    }
}

@section Menu {
    @{
        ViewData["ActiveMenu"] = "docking";
    }
    <partial name="_RaWorkspaceMenu" />
    <li class="nav-item active">
        <a class="nav-link" asp-controller="Job" asp-action="List" asp-route-domainId="@Model.DomainId">All Jobs</a>
    </li>
}
@section Styles {
    <style>
        :root {
            --ra-bg: #f7f9fc;
            --ra-surface: rgba(255,255,255,.86);
            --ra-surface-strong: rgba(255,255,255,.96);
            --ra-title: #162033;
            --ra-text: #627089;
            --ra-line: #dde6f2;
            --ra-blue: #2f6bff;
            --ra-blue-soft: rgba(47,107,255,.08);
            --ra-shadow: 0 18px 44px rgba(20, 44, 84, .06);
            --ra-shadow-card: 0 14px 28px rgba(20, 44, 84, .05);
            --ra-success: #1f9d67;
            --ra-danger: #d64545;
            --ra-warning: #c88409;
            --ra-secondary: #667085;
        }

        body {
            background: radial-gradient(circle at top left, rgba(47,107,255,.08), transparent 26%), radial-gradient(circle at bottom right, rgba(104,200,208,.08), transparent 24%), linear-gradient(180deg, #fbfdff 0%, #f6f9fc 100%);
            color: var(--ra-title);
        }

        .ra-jobs-page {
            width: min(1460px, calc(100vw - 2rem));
            margin: 0 auto;
            padding: 2rem 0 5rem;
        }

        .ra-section + .ra-section {
            margin-top: 1.8rem;
        }

        .ra-card-shell {
            background: var(--ra-surface);
            border: 1px solid var(--ra-line);
            border-radius: 28px;
            box-shadow: var(--ra-shadow);
            backdrop-filter: blur(8px);
        }

        .ra-header {
            padding: 2rem;
        }

        .ra-kicker {
            display: inline-flex;
            align-items: center;
            padding: .42rem .95rem;
            border-radius: 999px;
            background: var(--ra-blue-soft);
            color: var(--ra-blue);
            font-size: .82rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .ra-title {
            font-size: clamp(2.1rem, 3.7vw, 4rem);
            line-height: 1.04;
            font-weight: 800;
            letter-spacing: -.04em;
            margin-bottom: .9rem;
        }

        .ra-desc {
            color: var(--ra-text);
            font-size: 1.02rem;
            line-height: 1.9;
            max-width: 980px;
        }

        .ra-stats {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: .9rem;
            margin-top: 1.4rem;
        }

        .ra-stat {
            border: 1px solid var(--ra-line);
            border-radius: 20px;
            background: rgba(255,255,255,.96);
            padding: 1rem;
        }

        .ra-stat-value {
            font-size: 1.45rem;
            font-weight: 780;
            line-height: 1;
            margin-bottom: .35rem;
        }

        .ra-stat-label {
            color: var(--ra-text);
            font-size: .92rem;
            line-height: 1.6;
        }

        .ra-toolbar {
            padding: 1.25rem;
        }

        .ra-toolbar-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .ra-search-wrap {
            flex: 1 1 420px;
        }

        .ra-search {
            width: 100%;
            min-height: 48px;
            border-radius: 999px;
            border: 1px solid var(--ra-line);
            background: #fff;
            padding: 0 1rem;
            color: #24324a;
            outline: none;
        }

        .ra-actions {
            display: flex;
            gap: .75rem;
            flex-wrap: wrap;
        }

        .btn-ra-primary,
        .btn-ra-secondary {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 42px;
            border-radius: 999px;
            padding: 0 1rem;
            font-weight: 700;
            text-decoration: none !important;
        }

        .btn-ra-primary {
            color: #fff !important;
            background: var(--ra-blue);
        }

        .btn-ra-secondary {
            color: #24324a !important;
            background: #fff;
            border: 1px solid var(--ra-line);
        }

        .ra-filter-row {
            display: flex;
            gap: .6rem;
            flex-wrap: wrap;
            margin-top: 1rem;
        }

        .ra-filter-btn {
            border: 1px solid var(--ra-line);
            background: #fff;
            color: #2f405e;
            min-height: 36px;
            border-radius: 999px;
            padding: 0 .9rem;
            font-size: .9rem;
            font-weight: 650;
            cursor: pointer;
        }

            .ra-filter-btn.is-active {
                background: rgba(47,107,255,.08);
                border-color: rgba(47,107,255,.18);
                color: var(--ra-blue);
            }

        .ra-table-wrap {
            padding: 1.25rem;
        }

        .ra-table-shell {
            border: 1px solid var(--ra-line);
            border-radius: 24px;
            overflow: hidden;
            background: rgba(255,255,255,.97);
        }

        .ra-table {
            width: 100%;
            border-collapse: collapse;
        }

            .ra-table thead th {
                background: rgba(47,107,255,.05);
                color: #32517c;
                text-transform: uppercase;
                letter-spacing: .04em;
                font-size: .84rem;
                font-weight: 800;
                padding: .95rem 1rem;
                border-bottom: 1px solid var(--ra-line);
            }

            .ra-table tbody td {
                padding: 1rem;
                border-bottom: 1px solid var(--ra-line);
                vertical-align: middle;
            }

            .ra-table tbody tr:last-child td {
                border-bottom: 0;
            }

        .ra-job-name {
            font-weight: 760;
            line-height: 1.6;
        }

            .ra-job-name a {
                color: inherit;
                text-decoration: none;
            }

                .ra-job-name a:hover {
                    color: var(--ra-blue);
                }

        .ra-meta {
            color: var(--ra-text);
            font-size: .92rem;
            line-height: 1.7;
        }

        .ra-status-badge {
            display: inline-flex;
            align-items: center;
            min-height: 30px;
            padding: 0 .75rem;
            border-radius: 999px;
            font-size: .82rem;
            font-weight: 700;
            border: 1px solid transparent;
        }

            .ra-status-badge.success {
                color: var(--ra-success);
                background: rgba(31,157,103,.08);
                border-color: rgba(31,157,103,.18);
            }

            .ra-status-badge.primary {
                color: var(--ra-blue);
                background: rgba(47,107,255,.08);
                border-color: rgba(47,107,255,.18);
            }

            .ra-status-badge.warning {
                color: var(--ra-warning);
                background: rgba(200,132,9,.08);
                border-color: rgba(200,132,9,.18);
            }

            .ra-status-badge.danger {
                color: var(--ra-danger);
                background: rgba(214,69,69,.08);
                border-color: rgba(214,69,69,.18);
            }

            .ra-status-badge.secondary {
                color: var(--ra-secondary);
                background: rgba(102,112,133,.08);
                border-color: rgba(102,112,133,.18);
            }

        .ra-progress-wrap {
            min-width: 180px;
        }

        .ra-progress-bar {
            width: 100%;
            height: 8px;
            border-radius: 999px;
            background: #edf2f8;
            overflow: hidden;
            margin-bottom: .45rem;
        }

        .ra-progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #4b7dff, #69c8d0);
            border-radius: 999px;
        }

        .ra-row-actions {
            display: flex;
            gap: .45rem;
            flex-wrap: wrap;
        }

        .ra-action-btn {
            min-height: 36px;
            border-radius: 999px;
            padding: 0 .85rem;
            border: 1px solid var(--ra-line);
            background: #fff;
            color: #24324a;
            font-size: .88rem;
            font-weight: 700;
            text-decoration: none !important;
            cursor: pointer;
        }

            .ra-action-btn.primary {
                background: var(--ra-blue);
                color: #fff;
                border-color: var(--ra-blue);
            }

            .ra-action-btn.danger {
                color: var(--ra-danger);
                border-color: rgba(214,69,69,.22);
                background: rgba(214,69,69,.04);
            }

        .ra-rename-row {
            display: none;
            background: rgba(47,107,255,.03);
        }

        .ra-rename-box {
            display: flex;
            align-items: center;
            gap: .75rem;
            flex-wrap: wrap;
        }

        .ra-rename-input {
            flex: 1 1 340px;
            min-height: 42px;
            border-radius: 14px;
            border: 1px solid var(--ra-line);
            padding: 0 .9rem;
            background: #fff;
        }

        .ra-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
            margin-top: 1.2rem;
        }

        .ra-result-info {
            color: var(--ra-text);
            font-weight: 600;
            font-size: .95rem;
        }

        @@media (max-width: 1199.98px) {
            .ra-stats {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 991.98px) {
            .ra-stats {
                grid-template-columns: 1fr;
            }

            .ra-header,
            .ra-toolbar,
            .ra-table-wrap {
                padding: 1.25rem;
            }

            .ra-table-shell {
                overflow-x: auto;
            }

            .ra-table {
                min-width: 1180px;
            }
        }
    </style>
}

<div class="ra-jobs-page">
    <!-- Header -->
    <section class="ra-section ra-card-shell ra-header">
        <div class="ra-kicker">Job management • Search • Rename • Delete</div>

        <h1 class="ra-title">All Docking Jobs</h1>

        <p class="ra-desc">
            Monitor submitted docking jobs, reopen finished results, rename jobs for clarity,
            and delete completed or failed jobs when they are no longer needed.
        </p>

        <div class="ra-stats">
            <div class="ra-stat">
                <div class="ra-stat-value">@totalJobs</div>
                <div class="ra-stat-label">Total jobs in the current RA domain</div>
            </div>
            <div class="ra-stat">
                <div class="ra-stat-value">@runningJobs</div>
                <div class="ra-stat-label">Currently created or running jobs</div>
            </div>
            <div class="ra-stat">
                <div class="ra-stat-value">@finishedJobs</div>
                <div class="ra-stat-label">Finished jobs available for later inspection</div>
            </div>
            <div class="ra-stat">
                <div class="ra-stat-value">@failedJobs</div>
                <div class="ra-stat-label">Failed jobs that may be renamed or removed</div>
            </div>
        </div>
    </section>

    <!-- Toolbar -->
    <section class="ra-section ra-card-shell ra-toolbar">
        <div class="ra-toolbar-row">
            <div class="ra-search-wrap">
                <input id="raJobSearch"
                       class="ra-search"
                       type="text"
                       placeholder="Search by job name, job id, or ligand name..." />
            </div>

            <div class="ra-actions">
                <a class="btn-ra-primary"
                   asp-controller="Job"
                   asp-action="New"
                   asp-route-domainId="@Model.DomainId">
                    Create New Job
                </a>

                <a class="btn-ra-secondary"
                   asp-controller="Home"
                   asp-action="Index"
                   asp-route-domainId="@Model.DomainId">
                    Back to RA Workspace
                </a>
            </div>
        </div>

        <div class="ra-filter-row">
            <button type="button" class="ra-filter-btn is-active" data-status="all">All</button>
            <button type="button" class="ra-filter-btn" data-status="running">Running / Created</button>
            <button type="button" class="ra-filter-btn" data-status="finished">Finished</button>
            <button type="button" class="ra-filter-btn" data-status="failed">Failed</button>
        </div>
    </section>

    <!-- Table -->
    <section class="ra-section ra-card-shell ra-table-wrap">
        <div class="ra-table-shell">
            <table class="ra-table">
                <thead>
                    <tr>
                        <th>Job</th>
                        <th>Ligands</th>
                        <th>Created</th>
                        <th>Updated</th>
                        <th>Progress</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody id="raJobTableBody">
                    @foreach (var job in Model.Jobs)
                    {
                        var statusLabel = StatusLabel(job);
                        var statusClass = StatusClass(job);
                        var isOwner = User.Identity.IsAuthenticated && userName == job.UserId;
                        var canDelete = isOwner && (job.Status == RunningStatus.Finished || job.Status == RunningStatus.Failed || job.Status == RunningStatus.Running);
                        var canRename = isOwner;
                        var ligandText = !job.IsPrivate || isOwner
                        ? string.Join("; ", job.JobLigands.Select(o => o.LigandName))
                        : "***";

                        var searchText = $"{job.Id} {job.Name} {ligandText} {statusLabel}".ToLowerInvariant();
                        var statusKey = (job.Status == RunningStatus.Running || job.Status == RunningStatus.Created)
                        ? "running"
                        : (job.Status == RunningStatus.Finished ? "finished" : (job.Status == RunningStatus.Failed ? "failed" : "other"));

                        <tr class="ra-job-row"
                            data-status="@statusKey"
                            data-search="@searchText">
                            <td>
                                <div class="ra-job-name">
                                    @if (job.IsPrivate && !isOwner)
                                    {
                                        <text>
                                            #@job.Id @job.Name <i class="fas fa-lock"></i>
                                        </text>
                                    }
                                    else
                                    {
                                        <a asp-controller="Job"
                                           asp-action="Details"
                                           asp-route-domainId="@Model.DomainId"
                                           asp-route-jobId="@job.Id">
                                            #@job.Id @job.Name
                                            @if (job.IsPrivate)
                                            {
                                                <i class="fas fa-lock-open"></i>
                                            }
                                        </a>
                                    }
                                </div>
                                <div class="ra-meta">
                                    Owner: @(string.IsNullOrWhiteSpace(job.UserId) ? "Public" : job.UserId)
                                </div>
                            </td>

                            <td>
                                <div class="ra-meta">
                                    <strong>@job.LigandCount</strong> ligand(s)<br />
                                    @ligandText
                                </div>
                            </td>

                            <td>
                                <div class="ra-meta update-utms" data-utms="@job.Created.UtcToUnixTimeMilliseconds()"></div>
                            </td>

                            <td>
                                <div class="ra-meta update-utms" data-utms="@job.Updated.UtcToUnixTimeMilliseconds()"></div>
                            </td>

                            <td>
                                <div class="ra-progress-wrap">
                                    <div class="ra-progress-bar">
                                        <div class="ra-progress-fill" style="width:@(job.Progress * 100)%"></div>
                                    </div>
                                    <div class="ra-meta">@job.Progress.ToString("P")</div>
                                </div>
                            </td>

                            <td>
                                <span class="ra-status-badge @statusClass">@statusLabel</span>
                            </td>

                            <td>
                                <div class="ra-row-actions">
                                    @if (!(job.IsPrivate && !isOwner))
                                    {
                                        <a class="ra-action-btn primary"
                                           asp-controller="Job"
                                           asp-action="Details"
                                           asp-route-domainId="@Model.DomainId"
                                           asp-route-jobId="@job.Id">
                                            Open
                                        </a>
                                    }

                                    @if (canRename)
                                    {
                                        <button type="button"
                                                class="ra-action-btn"
                                                data-toggle-rename="@job.Id">
                                            Rename
                                        </button>
                                    }

                                    @if (canDelete)
                                    {
                                        <form asp-controller="Job"
                                              asp-action="Delete"
                                              asp-route-domainId="@Model.DomainId"
                                              asp-route-jobId="@job.Id"
                                              method="post"
                                              style="display:inline"
                                              onsubmit="return confirm('Delete job #@job.Id permanently?');">
                                            <button type="submit" class="ra-action-btn danger">
                                                Delete
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>

                        @if (canRename)
                        {
                            <tr class="ra-rename-row" id="rename-row-@job.Id">
                                <td colspan="7">
                                    <form asp-controller="Job"
                                          asp-action="Rename"
                                          asp-route-domainId="@Model.DomainId"
                                          asp-route-jobId="@job.Id"
                                          method="post">
                                        <div class="ra-rename-box">
                                            <input class="ra-rename-input"
                                                   type="text"
                                                   name="newName"
                                                   value="@job.Name"
                                                   placeholder="Enter a new job name" />
                                            <button type="submit" class="ra-action-btn primary">Save</button>
                                            <button type="button" class="ra-action-btn" data-close-rename="@job.Id">Cancel</button>
                                        </div>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="ra-footer">
            <div class="ra-result-info">
                <span id="raVisibleJobCount">@Model.Jobs.Count</span> visible jobs
            </div>

            <div class="ra-actions">
                <a class="btn-ra-secondary"
                   asp-controller="Home"
                   asp-action="Targets"
                   asp-route-domainId="@Model.DomainId">
                    Browse Protein Database
                </a>

                <a class="btn-ra-primary"
                   asp-controller="Job"
                   asp-action="New"
                   asp-route-domainId="@Model.DomainId">
                    Create Another Job
                </a>
            </div>
        </div>
    </section>
</div>
}
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const searchInput = document.getElementById("raJobSearch");
            const filterButtons = Array.from(document.querySelectorAll(".ra-filter-btn"));
            const jobRows = Array.from(document.querySelectorAll(".ra-job-row"));
            const renameRows = Array.from(document.querySelectorAll(".ra-rename-row"));
            const visibleCount = document.getElementById("raVisibleJobCount");

            let activeStatus = "all";

            function applyFilters() {
                const query = (searchInput.value || "").trim().toLowerCase();
                let count = 0;

                renameRows.forEach(row => row.style.display = "none");

                jobRows.forEach(row => {
                    const status = row.getAttribute("data-status") || "";
                    const text = (row.getAttribute("data-search") || "").toLowerCase();

                    const matchStatus = activeStatus === "all" || status === activeStatus;
                    const matchText = !query || text.includes(query);
                    const visible = matchStatus && matchText;

                    row.style.display = visible ? "" : "none";
                    if (visible) count++;
                });

                visibleCount.textContent = count.toString();
            }

            filterButtons.forEach(btn => {
                btn.addEventListener("click", function () {
                    filterButtons.forEach(x => x.classList.remove("is-active"));
                    this.classList.add("is-active");
                    activeStatus = this.getAttribute("data-status") || "all";
                    applyFilters();
                });
            });

            if (searchInput) {
                searchInput.addEventListener("input", applyFilters);
            }

            document.querySelectorAll("[data-toggle-rename]").forEach(btn => {
                btn.addEventListener("click", function () {
                    const id = this.getAttribute("data-toggle-rename");
                    const row = document.getElementById("rename-row-" + id);
                    if (row) {
                        row.style.display = row.style.display === "table-row" ? "none" : "table-row";
                    }
                });
            });

            document.querySelectorAll("[data-close-rename]").forEach(btn => {
                btn.addEventListener("click", function () {
                    const id = this.getAttribute("data-close-rename");
                    const row = document.getElementById("rename-row-" + id);
                    if (row) {
                        row.style.display = "none";
                    }
                });
            });

            applyFilters();
        });
    </script>
}